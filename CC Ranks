<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Creator Dashboard - Admin User-Verwaltung</title>
    <style>
        :root {
            --bg-color: #0f1115;
            --panel-bg: #161920;
            --text-color: #ffffff;
            --text-secondary: #94a3b8;
            --border-color: #1e293b;
            --primary-color: #2563eb;
            --primary-hover: #1d4ed8;
            
            --tier-1: #ef4444; 
            --tier-2: #3b82f6; 
            --tier-3: #eab308; 
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            display: none;
        }

        .auth-card {
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color);
            padding: 30px;
            border-radius: 16px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
        }

        .auth-card h2 {
            font-size: 1.6rem;
            margin-bottom: 8px;
            text-align: center;
        }

        .auth-card p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            text-align: center;
            margin-bottom: 24px;
        }

        .auth-toggle {
            text-align: center;
            margin-top: 15px;
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .auth-toggle span {
            color: var(--primary-color);
            cursor: pointer;
            font-weight: bold;
        }

        .auth-toggle span:hover {
            text-decoration: underline;
        }

        header {
            margin-bottom: 30px;
            text-align: center;
        }

        header h1 {
            font-size: 2.2rem;
            margin-bottom: 8px;
        }

        header p {
            color: var(--text-secondary);
        }

        .user-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #1e293b;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 25px;
        }

        .btn-logout {
            background-color: #ef4444;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
        }

        .admin-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        @media (max-width: 768px) {
            .admin-grid {
                grid-template-columns: 1fr;
            }
        }

        .admin-only {
            display: none;
        }

        .panel {
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color);
            padding: 20px;
            border-radius: 12px;
        }

        .panel h2 {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: #fff;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 8px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            align-items: flex-end;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            margin-bottom: 12px;
        }

        .form-group label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 6px;
        }

        .form-group input, .form-group select {
            background-color: #0f1115;
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 10px;
            border-radius: 6px;
            font-size: 0.95rem;
            outline: none;
        }

        .btn-action {
            background-color: var(--primary-color);
            color: #fff;
            border: none;
            padding: 11px;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
        }

        .btn-action:hover {
            background-color: var(--primary-hover);
        }

        .user-list {
            list-style: none;
            max-height: 220px;
            overflow-y: auto;
            padding-right: 5px;
        }

        .user-item {
            background-color: #0f1115;
            border: 1px solid var(--border-color);
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.9rem;
        }

        .user-email {
            font-weight: 500;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 55%;
        }

        .filter-panel {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-btn {
            background-color: #1e293b;
            color: #fff;
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.85rem;
        }

        .filter-btn.active {
            background-color: var(--primary-color);
        }

        .table-responsive {
            width: 100%;
            overflow-x: auto;
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            background-color: #1e293b;
            color: var(--text-secondary);
            font-size: 0.85rem;
            text-transform: uppercase;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .badge-tier-1 { background-color: rgba(239, 68, 68, 0.15); color: var(--tier-1); }
        .badge-tier-2 { background-color: rgba(59, 130, 246, 0.15); color: var(--tier-2); }
        .badge-tier-3 { background-color: rgba(234, 179, 8, 0.15); color: var(--tier-3); }

        .badge-admin-user { background-color: rgba(234, 179, 8, 0.2); color: var(--tier-3); font-size: 0.75rem; }
        .badge-normal-user { background-color: rgba(148, 163, 184, 0.15); color: var(--text-secondary); font-size: 0.75rem; }
        .badge-banned { background-color: rgba(239, 68, 68, 0.2); color: #ef4444; font-size: 0.75rem; }

        .table-link { color: #3b82f6; text-decoration: none; }

        .rank-actions, .user-actions {
            display: flex;
            gap: 5px;
        }

        .btn-rank, .btn-user-action {
            padding: 4px 8px;
            border-radius: 4px;
            border: none;
            cursor: pointer;
            font-weight: bold;
            font-size: 0.8rem;
        }

        .btn-up { background-color: #22c55e; color: white; }
        .btn-down { background-color: #a855f7; color: white; }
        .btn-del { background-color: #ef4444; color: white; }
        .btn-ban { background-color: #ef4444; color: white; }

        .empty-message { text-align: center; color: var(--text-secondary); padding: 30px; font-style: italic; }

        .message {
            padding: 10px;
            margin: 10px 0;
            border-radius: 6px;
            font-size: 0.9rem;
            text-align: center;
        }
        .success { background-color: rgba(34, 197, 94, 0.2); color: #22c55e; }
        .error { background-color: rgba(239, 68, 68, 0.2); color: #ef4444; }
    </style>
</head>
<body>

    <div class="auth-card" id="authCard">
        <h2 id="authTitle">Anmelden</h2>
        <p id="authDesc">Logge dich mit deiner echten E-Mail ein.</p>
        
        <form id="authForm" onsubmit="handleAuth(event)">
            <div class="form-group">
                <label for="authEmail">E-Mail Adresse <span style="color:#ef4444;">*</span></label>
                <input type="email" id="authEmail" required placeholder="deine@echte-email.de">
            </div>
            <div class="form-group">
                <label for="authPassword">Passwort</label>
                <input type="password" id="authPassword" required placeholder="••••••••" minlength="6">
            </div>
            <button type="submit" class="btn-action" id="authBtn" style="width: 100%; margin-top: 10px;">Einloggen</button>
        </form>

        <div class="auth-toggle" id="authToggleText">
            Noch keinen Account? <span onclick="switchAuthMode(true)">Jetzt registrieren</span>
        </div>
    </div>

    <div class="container" id="mainDashboard">
        <header>
            <h1>Creator & Admin Netzwerk</h1>
            <p>Übersicht aller verifizierten Content Creator</p>
        </header>

        <div class="user-bar">
            <div>Eingeloggt als: <strong id="currentUserText">Unbekannt</strong> <span id="adminBadge" class="badge badge-tier-3" style="display:none; margin-left:10px;">Admin</span></div>
            <button class="btn-logout" onclick="logout()">Abmelden</button>
        </div>

        <div class="admin-grid admin-only">
            <div class="panel">
                <h2>Neuen Creator hinzufügen</h2>
                <form id="creatorForm" onsubmit="addCreator(event)">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Name / Displayname</label>
                            <input type="text" id="name" required placeholder="z.B. Alex">
                        </div>
                        <div class="form-group">
                            <label>Stufe (1-3)</label>
                            <select id="tier" required>
                                <option value="1">Stufe 1</option>
                                <option value="2">Stufe 2</option>
                                <option value="3">Stufe 3</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>TikTok Name</label>
                            <input type="text" id="tiktok" required placeholder="z.B. @alex_clips">
                        </div>
                        <div class="form-group">
                            <label>Roblox Name</label>
                            <input type="text" id="roblox" required placeholder="z.B. AlexRoblox">
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label>Account Link (URL)</label>
                            <input type="url" id="link" required placeholder="https://tiktok.com/...">
                        </div>
                        <button type="submit" class="btn-action" style="grid-column: span 2; margin-top: 5px;">Creator Hinzufügen</button>
                    </div>
                </form>
            </div>

            <div class="panel">
                <h2>Registrierte Accounts</h2>
                <ul class="user-list" id="registeredUserList"></ul>
            </div>
        </div>

        <div class="filter-panel">
            <button class="filter-btn active" id="btn-all" onclick="setFilter('all')">Alle anzeigen</button>
            <button class="filter-btn" id="btn-sort" onclick="setFilter('sort')">Nach Stufe (1➔2➔3)</button>
            <button class="filter-btn" id="btn-1" onclick="setFilter('1')">Stufe 1</button>
            <button class="filter-btn" id="btn-2" onclick="setFilter('2')">Stufe 2</button>
            <button class="filter-btn" id="btn-3" onclick="setFilter('3')">Stufe 3</button>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Stufe</th>
                        <th>TikTok</th>
                        <th>Roblox Name</th>
                        <th>Account Link</th>
                        <th class="admin-only">Admin Aktionen</th>
                    </tr>
                </thead>
                <tbody id="creatorTableBody"></tbody>
            </table>
            <div id="emptyNotice" class="empty-message">Noch keine Creator eingetragen.</div>
        </div>
    </div>

    <script>
        let creators = JSON.parse(localStorage.getItem('secureCreators')) || [];
        let users = JSON.parse(localStorage.getItem('registeredUsers')) || [];
        let loggedInUser = JSON.parse(sessionStorage.getItem('activeUser')) || null;

        let currentFilter = 'all';
        let isRegisterMode = false;

        const ADMINS = [
            "jonasterpitz@gmail.com",
            "emdenflopi.kooperation@gmx.de"
        ];

        function isAdminUser(email) {
            if (!email) return false;
            const lowerEmail = email.toLowerCase().trim();
            return ADMINS.some(admin => admin.toLowerCase() === lowerEmail);
        }

        function switchAuthMode(toRegister) {
            isRegisterMode = toRegister;
            const title = document.getElementById('authTitle');
            const desc = document.getElementById('authDesc');
            const btn = document.getElementById('authBtn');
            const toggleText = document.getElementById('authToggleText');

            if (toRegister) {
                title.innerText = "Registrieren";
                desc.innerText = "Erstelle ein Konto mit deiner echten E-Mail.";
                btn.innerText = "Konto erstellen";
                toggleText.innerHTML = `Bereits ein Konto? <span onclick="switchAuthMode(false)">Jetzt einloggen</span>`;
            } else {
                title.innerText = "Anmelden";
                desc.innerText = "Logge dich mit deiner echten E-Mail ein.";
                btn.innerText = "Einloggen";
                toggleText.innerHTML = `Noch kein Konto? <span onclick="switchAuthMode(true)">Jetzt registrieren</span>`;
            }
        }

        function handleAuth(event) {
            event.preventDefault();
            let email = document.getElementById('authEmail').value.trim();
            const password = document.getElementById('authPassword').value;

            if (!email.includes('@')) {
                showMessage("Bitte eine gültige E-Mail-Adresse eingeben!", "error");
                return;
            }

            if (isRegisterMode) {
                const lowerEmail = email.toLowerCase();
                if (users.some(u => u.email.toLowerCase() === lowerEmail)) {
                    showMessage("Diese E-Mail ist bereits registriert!", "error");
                    return;
                }
                const isAdmin = isAdminUser(email);
                users.push({ email: email, password: password, isAdmin: isAdmin, banned: false });
                localStorage.setItem('registeredUsers', JSON.stringify(users));
                showMessage("Registrierung erfolgreich!", "success");
                switchAuthMode(false);
            } else {
                const user = users.find(u => u.email.toLowerCase() === email.toLowerCase() && u.password === password && !u.banned);
                if (user) {
                    loggedInUser = user;
                    sessionStorage.setItem('activeUser', JSON.stringify(loggedInUser));
                    checkScreenState();
                } else {
                    showMessage("Falsche E-Mail, Passwort oder Account gesperrt!", "error");
                }
            }
        }

        function showMessage(text, type) {
            const msg = document.createElement('div');
            msg.className = `message ${type}`;
            msg.textContent = text;
            document.getElementById('authCard').appendChild(msg);
            setTimeout(() => msg.remove(), 4000);
        }

        function logout() {
            loggedInUser = null;
            sessionStorage.removeItem('activeUser');
            checkScreenState();
        }

        function banUser(index) {
            if (!loggedInUser || !isAdminUser(loggedInUser.email)) return;
            if (confirm("Diesen User wirklich bannen?")) {
                users[index].banned = true;
                localStorage.setItem('registeredUsers', JSON.stringify(users));
                renderUserList();
                showMessage("User wurde gebannt.", "success");
            }
        }

        function unbanUser(index) {
            if (!loggedInUser || !isAdminUser(loggedInUser.email)) return;
            users[index].banned = false;
            localStorage.setItem('registeredUsers', JSON.stringify(users));
            renderUserList();
            showMessage("User wurde entbannt.", "success");
        }

        function deleteUser(index) {
            if (!loggedInUser || !isAdminUser(loggedInUser.email)) return;
            if (confirm("User endgültig löschen?")) {
                users.splice(index, 1);
                localStorage.setItem('registeredUsers', JSON.stringify(users));
                renderUserList();
            }
        }

        function checkScreenState() {
            const authCard = document.getElementById('authCard');
            const mainDashboard = document.getElementById('mainDashboard');
            const currentUserText = document.getElementById('currentUserText');
            const adminBadge = document.getElementById('adminBadge');
            const adminPanels = document.querySelectorAll('.admin-only');

            if (loggedInUser) {
                authCard.style.display = "none";
                mainDashboard.style.display = "block";
                document.body.style.justifyContent = "flex-start";
                currentUserText.innerText = loggedInUser.email;

                const isAdmin = isAdminUser(loggedInUser.email);
                
                if (isAdmin) {
                    adminBadge.style.display = "inline-block";
                    adminPanels.forEach(el => el.style.display = "block");
                    document.querySelectorAll('th.admin-only, td.admin-only').forEach(el => el.style.display = "table-cell");
                    renderUserList();
                } else {
                    adminBadge.style.display = "none";
                    adminPanels.forEach(el => el.style.display = "none");
                }
                renderTable();
            } else {
                authCard.style.display = "block";
                mainDashboard.style.display = "none";
                document.body.style.justifyContent = "center";
            }
        }

        function renderUserList() {
            const listElement = document.getElementById('registeredUserList');
            listElement.innerHTML = '';

            users.forEach((user, index) => {
                const li = document.createElement('li');
                li.className = 'user-item';
                
                const roleBadge = user.banned ? 
                    `<span class="badge badge-banned">GEBANNT</span>` : 
                    (isAdminUser(user.email) ? 
                        `<span class="badge badge-admin-user">Admin</span>` : 
                        `<span class="badge badge-normal-user">User</span>`);

                let actions = '';
                if (isAdminUser(loggedInUser.email)) {
                    actions = user.banned ? 
                        `<button class="btn-user-action" style="background:#22c55e" onclick="unbanUser(${index})">Entbannen</button>` :
                        `<button class="btn-user-action btn-ban" onclick="banUser(${index})">Bannen</button>`;
                    actions += `<button class="btn-user-action btn-del" onclick="deleteUser(${index})">Löschen</button>`;
                }

                li.innerHTML = `
                    <span class="user-email" title="${user.email}">${user.email}</span>
                    ${roleBadge}
                    <div class="user-actions">${actions}</div>
                `;
                listElement.appendChild(li);
            });

            if (users.length === 0) {
                listElement.innerHTML = '<li style="color: var(--text-secondary); font-style: italic;">Keine User registriert.</li>';
            }
        }

        // Rest der Funktionen (addCreator, changeRank, renderTable, etc.) bleiben gleich
        function setFilter(filterType) {
            currentFilter = filterType;
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            const btn = document.getElementById('btn-' + filterType) || document.getElementById('btn-all');
            btn.classList.add('active');
            renderTable();
        }

        function changeRank(index, direction) {
            if (!loggedInUser || !isAdminUser(loggedInUser.email)) return;
            let currentTier = parseInt(creators[index].tier);
            if (direction === 'up' && currentTier < 3) creators[index].tier = (currentTier + 1).toString();
            else if (direction === 'down' && currentTier > 1) creators[index].tier = (currentTier - 1).toString();
            localStorage.setItem('secureCreators', JSON.stringify(creators));
            renderTable();
        }

        function addCreator(event) {
            event.preventDefault();
            if (!loggedInUser || !isAdminUser(loggedInUser.email)) return;

            const newCreator = {
                name: document.getElementById('name').value.trim(),
                tier: document.getElementById('tier').value,
                tiktok: document.getElementById('tiktok').value.trim(),
                roblox: document.getElementById('roblox').value.trim(),
                link: document.getElementById('link').value.trim()
            };
            
            creators.push(newCreator);
            localStorage.setItem('secureCreators', JSON.stringify(creators));
            renderTable();
            document.getElementById('creatorForm').reset();
            showMessage("Creator erfolgreich hinzugefügt!", "success");
        }

        function deleteCreator(index) {
            if (!loggedInUser || !isAdminUser(loggedInUser.email)) return;
            creators.splice(index, 1);
            localStorage.setItem('secureCreators', JSON.stringify(creators));
            renderTable();
        }

        function renderTable() {
            const tbody = document.getElementById('creatorTableBody');
            const emptyNotice = document.getElementById('emptyNotice');
            tbody.innerHTML = '';

            let displayList = [...creators];

            if (currentFilter === 'sort') {
                displayList.sort((a, b) => parseInt(a.tier) - parseInt(b.tier));
            } else if (['1', '2', '3'].includes(currentFilter)) {
                displayList = displayList.filter(c => c.tier === currentFilter);
            }

            emptyNotice.style.display = displayList.length === 0 ? 'block' : 'none';

            displayList.forEach((creator) => {
                const originalIndex = creators.indexOf(creator);
                const tr = document.createElement('tr');
                const isAdmin = loggedInUser && isAdminUser(loggedInUser.email);
                
                tr.innerHTML = `
                    <td style="font-weight: bold;">${creator.name}</td>
                    <td><span class="badge badge-tier-${creator.tier}">Stufe ${creator.tier}</span></td>
                    <td>${creator.tiktok}</td>
                    <td>${creator.roblox}</td>
                    <td><a href="${creator.link}" target="_blank" class="table-link">Link öffnen ➔</a></td>
                    <td class="admin-only" style="display: ${isAdmin ? 'table-cell' : 'none'};">
                        <div class="rank-actions">
                            <button class="btn-rank btn-up" onclick="changeRank(${originalIndex}, 'up')" ${creator.tier == 3 ? 'disabled style="opacity:0.3; cursor:default;"' : ''}>▲ Stufe hoch</button>
                            <button class="btn-rank btn-down" onclick="changeRank(${originalIndex}, 'down')" ${creator.tier == 1 ? 'disabled style="opacity:0.3; cursor:default;"' : ''}>▼ Stufe runter</button>
                            <button class="btn-rank btn-del" onclick="deleteCreator(${originalIndex})">Löschen</button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        checkScreenState();
    </script>
</body>
</html>
